{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd web && npm install && cd ../server && npm install",
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/out",
  "functions": {
    "server/index.ts": {
      "maxDuration": 60,
      "includeFiles": "server/src/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server/index.ts"
    }
  ]
}
