{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd web && npm install && cd ../server && npm install",
  "buildCommand": "cd server && npm run build && cd ../web && npm run build",
  "outputDirectory": "web/out",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": ["server/dist/**", "server/node_modules/**"]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ]
}
